DATABASE_URL=mssql+pyodbc://your_user:your_password@your_host/your_db?driver=ODBC+Driver+17+for+SQL+Server

OPENAI_API_KEY=your_key_here
SONIOX_API_KEY=your_key_here

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com

GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-3.1-flash-lite-preview
XAI_API_KEY=your_key_here
GROQ_API_KEY=your_key_here

# ===== BILLING CONFIG =====
BASE_URL=https://your-domain.com
FRONTEND_URL=https://your-domain.com
# Enable credit debit on API usage
BILLING_DEBIT=1

# Enforce minimum credit balance (1=yes, 0=no)
BILLING_ENFORCE=1

# MoMo Sandbox Credentials
MOMO_PARTNER_CODE=MOMO
MOMO_ACCESS_KEY=your_key_here
MOMO_SECRET_KEY=your_key_here
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create

# ZaloPay Sandbox Credentials
ZALOPAY_APP_ID=your_id_here
ZALOPAY_KEY1=your_key_here
ZALOPAY_KEY2=your_key_here
ZALOPAY_ENDPOINT=https://sb-openapi.zalopay.vn/v2/create
